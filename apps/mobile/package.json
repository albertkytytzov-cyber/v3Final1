{
  "name": "@training-platform/mobile",
  "private": true,
  "version": "0.1.0",
  "scripts": {
    "build": "node scripts/build-mobile-assets.mjs && tsc --project tsconfig.json",
    "sync": "npm run build && cap sync",
    "sync:android": "npm run build && cap sync android",
    "sync:ios": "npm run build && cap sync ios",
    "typecheck": "tsc --project tsconfig.json --noEmit",
    "open:android": "cap open android",
    "open:ios": "cap open ios"
  },
  "dependencies": {
    "@capacitor/android": "^8.3.1",
    "@capacitor/core": "^8.3.1",
    "@capacitor/ios": "^8.3.1",
    "@training-platform/shared": "0.1.0"
  },
  "devDependencies": {
    "@capacitor/cli": "^8.3.1"
  }
}
