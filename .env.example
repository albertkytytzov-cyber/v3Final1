# Application
APP_NAME=PERFORM
NODE_ENV=development

# Local ports and bind addresses
WEB_PORT=3000
API_PORT=4000
HTTP_PORT=80
HTTPS_PORT=443
WEB_BIND_ADDRESS=127.0.0.1
API_BIND_ADDRESS=127.0.0.1
POSTGRES_BIND_ADDRESS=127.0.0.1
REDIS_BIND_ADDRESS=127.0.0.1
WEB_PUBLISHED_PORT=3000
API_PUBLISHED_PORT=4000
POSTGRES_PUBLISHED_PORT=5432
REDIS_PUBLISHED_PORT=6379

# Public web/API routing
NEXT_PUBLIC_API_BASE_URL=/api/v1
NEXT_PUBLIC_MOBILE_APP_DOWNLOAD_URL=/downloads/perform-mobile-android.apk
PUBLIC_HOST=change-me.example.com
CORS_ORIGINS=
API_HOST=0.0.0.0
API_BASE_URL=http://localhost:4000

# Data stores
POSTGRES_DB=training_platform
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me-postgres-password
DATABASE_URL=postgresql://postgres:change-me-postgres-password@localhost:5432/training_platform
REDIS_URL=redis://localhost:6379

# Sessions
SESSION_COOKIE_NAME=training_platform_session
SESSION_COOKIE_SECURE=true
SESSION_SECRET=change-me-in-production

# Demo data and background jobs
SEED_DEMO_DATA=false
WORKER_INTERVAL_MS=60000
SCHEDULER_INTERVAL_MS=300000
BACKUP_RETENTION_DAYS=14
