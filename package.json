{
  "name": "training-process-platform",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "postinstall": "npm run build --workspace @training-platform/shared",
    "setup": "npm ci",
    "run": "npm run dev",
    "test": "npm run check:mobile-release-config && npm run check:device-health-protection && npm run check:direct-watch-parser-coverage && npm run check:mobile-workout-performance && npm run check:import-template && npm run check:constructor-core && npm run check:constructor-matrix-ai-review-policy && npm run check:constructor-matrix-evidence-dependencies && npm run check:constructor-matrix-data-dependencies && npm run check:constructor-matrix-threshold-candidates && npm run check:constructor-matrix-review-package && npm run check:constructor-matrix-review-decision-ledger && npm run check:constructor-matrix-source-expansion-backlog && npm run check:constructor-matrix-source-candidates && npm run check:constructor-matrix-source-lookup-intake && npm run check:constructor-matrix-ai-source-review && npm run check:constructor-matrix-evidence-claims && npm run check:constructor-matrix-ai-evidence-claims && npm run check:constructor-matrix-ai-safety-classification && npm run check:constructor-matrix-runtime-eligibility && npm run check:constructor-matrix-ai-runtime-integration && npm run check:constructor-matrix-ai-save-assign-readiness && npm run check:constructor-matrix-ai-production-decision-pack && npm run check:constructor-matrix-ai-production-deployment-gate && npm run check:constructor-matrix-dependency-map && npm run check:constructor-matrix-evidence-claim-review-intake && npm run check:constructor-matrix-review-intake-export && npm run check:constructor-matrix-desk-source-review-and-claim-candidates && npm run check:constructor-matrix-evidence-claim-candidate-review-export && npm run check:constructor-matrix-ui-gates && npm run check:constructor-matrix-review-export && npm run check:constructor-matrix-production-rollout",
    "check": "npm run lint && npm run typecheck && npm run test",
    "check:device-health-protection": "node --import tsx scripts/check-device-health-data-protection.mjs",
    "check:direct-watch-parser-coverage": "node scripts/check-direct-watch-parser-coverage.mjs",
    "check:mobile-workout-performance": "node scripts/check-mobile-workout-performance-guards.mjs",
    "check:mobile-release-config": "node scripts/check-mobile-release-config.mjs",
    "check:import-template": "node scripts/check-perform-template-import.mjs",
    "check:constructor-core": "node scripts/check-perform-constructor-core.mjs",
    "check:constructor-matrix-ai-review-policy": "node --import tsx scripts/check-constructor-matrix-ai-review-policy.mjs",
    "check:constructor-matrix-evidence-dependencies": "node --import tsx scripts/check-constructor-matrix-evidence-dependencies.mjs",
    "check:constructor-matrix-data-dependencies": "node --import tsx scripts/check-constructor-matrix-data-dependencies.mjs",
    "check:constructor-matrix-threshold-candidates": "node --import tsx scripts/check-constructor-matrix-threshold-candidates.mjs",
    "check:constructor-matrix-review-package": "node --import tsx scripts/check-constructor-matrix-review-package.mjs",
    "check:constructor-matrix-review-decision-ledger": "node --import tsx scripts/check-constructor-matrix-review-decision-ledger.mjs",
    "check:constructor-matrix-source-expansion-backlog": "node scripts/check-constructor-matrix-source-expansion-backlog.mjs",
    "check:constructor-matrix-source-candidates": "node scripts/check-constructor-matrix-source-candidates.mjs",
    "check:constructor-matrix-source-lookup-intake": "node scripts/check-constructor-matrix-source-lookup-intake.mjs",
    "check:constructor-matrix-ai-source-review": "node --import tsx scripts/check-constructor-matrix-ai-source-review.mjs",
    "check:constructor-matrix-evidence-claims": "node scripts/check-constructor-matrix-evidence-claims.mjs",
    "check:constructor-matrix-ai-evidence-claims": "node --import tsx scripts/check-constructor-matrix-ai-evidence-claims.mjs",
    "check:constructor-matrix-ai-safety-classification": "node --import tsx scripts/check-constructor-matrix-ai-safety-classification.mjs",
    "check:constructor-matrix-runtime-eligibility": "node --import tsx scripts/check-constructor-matrix-runtime-eligibility.mjs",
    "check:constructor-matrix-ai-runtime-integration": "node --import tsx scripts/check-constructor-matrix-ai-runtime-integration.mjs",
    "check:constructor-matrix-ai-save-assign-readiness": "node --import tsx scripts/check-constructor-matrix-ai-save-assign-readiness.mjs",
    "check:constructor-matrix-ai-production-decision-pack": "node --import tsx scripts/check-constructor-matrix-ai-production-decision-pack.mjs",
    "check:constructor-matrix-ai-production-deployment-gate": "node --import tsx scripts/check-constructor-matrix-ai-production-deployment-gate.mjs",
    "check:constructor-matrix-dependency-map": "node --import tsx scripts/check-constructor-matrix-dependency-map.mjs",
    "check:constructor-matrix-evidence-claim-review-intake": "node scripts/check-constructor-matrix-evidence-claim-review-intake.mjs",
    "check:constructor-matrix-review-intake-export": "node scripts/check-constructor-matrix-review-intake-export.mjs",
    "check:constructor-matrix-desk-source-review-and-claim-candidates": "node scripts/check-constructor-matrix-desk-source-review-and-claim-candidates.mjs",
    "check:constructor-matrix-evidence-claim-candidate-review-export": "node scripts/check-constructor-matrix-evidence-claim-candidate-review-export.mjs",
    "generate:constructor-matrix-review-intake-export": "node scripts/generate-constructor-matrix-review-intake-export.mjs",
    "generate:constructor-matrix-evidence-claim-candidate-review-export": "node scripts/generate-constructor-matrix-evidence-claim-candidate-review-export.mjs",
    "check:constructor-matrix-ui-gates": "node --import tsx scripts/check-constructor-matrix-ui-gates.mjs",
    "check:constructor-matrix-review-export": "node --import tsx scripts/check-constructor-matrix-review-export.mjs",
    "check:constructor-matrix-production-rollout": "node scripts/check-constructor-matrix-production-rollout.mjs",
    "dev": "npm-run-all --parallel dev:web dev:api",
    "dev:web": "npm run dev --workspace @training-platform/web",
    "dev:api": "npm run dev --workspace @training-platform/api",
    "build": "npm run build --workspace @training-platform/shared && npm run build --workspace @training-platform/api && npm run build --workspace @training-platform/web && npm run build --workspace @training-platform/mobile",
    "lint": "npm run lint --workspace @training-platform/web",
    "mobile:build": "npm run build --workspace @training-platform/mobile",
    "mobile:sync": "npm run sync --workspace @training-platform/mobile",
    "mobile:sync:android": "npm run sync:android --workspace @training-platform/mobile",
    "mobile:sync:ios": "npm run sync:ios --workspace @training-platform/mobile",
    "mobile:open:android": "npm run open:android --workspace @training-platform/mobile",
    "mobile:open:ios": "npm run open:ios --workspace @training-platform/mobile",
    "typecheck": "npm run typecheck --workspace @training-platform/shared && npm run typecheck --workspace @training-platform/api && npm run typecheck --workspace @training-platform/web && npm run typecheck --workspace @training-platform/mobile"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/node": "^24.8.1",
    "@typescript-eslint/eslint-plugin": "^8.46.2",
    "@typescript-eslint/parser": "^8.46.2",
    "eslint": "^9.39.1",
    "globals": "^16.4.0",
    "npm-run-all": "^4.1.5",
    "typescript": "^6.0.3"
  }
}
